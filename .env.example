# Copy to .env.local and fill in when you wire up Supabase (spec §9).
# .env.local is gitignored — never commit real keys.

NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Server-only (used by edge/route handlers that apply Elo + approve revisions)
SUPABASE_SERVICE_ROLE_KEY=

# Admin-only: direct Postgres connection string (Settings -> Database in the
# Supabase dashboard). Only used by scripts/apply-schema.ts and scripts/seed.ts
# to run DDL and seed data as the postgres superuser. Never used by the app.
SUPABASE_DB_URL=
